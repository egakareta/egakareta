{
    "name": "egakareta",
    "scripts": {
        "build": "wasm-pack build -t web -d dist/pkg && bun dist.ts",
        "format:cargo": "cargo fmt",
        "format:prettier": "prettier --write .",
        "format": "bun run format:cargo && bun run format:prettier",
        "lint": "cargo clippy -- -D warnings",
        "sync-env": "supabase status -o env > .env.local",
        "cf-typegen": "wrangler types --env-interface CloudflareEnv functions/cloudflare-env.d.ts",
        "sb-ts-typegen": "supabase gen types typescript --local > functions/_supabase_types.ts",
        "typegen": "bun cf-typegen && bun sb-ts-typegen",
        "test": "cargo test -- -Zunstable-options --report-time",
        "test:coverage": "cargo llvm-cov --lcov --output-path lcov.info -- -Zunstable-options --report-time",
        "test:db": "supabase test db",
        "license:add": "license-check-and-add add -f license-checker-config.json",
        "license:check": "license-check-and-add check -f license-checker-config.json",
        "watch": "nodemon --exec \"bun run build\"",
        "dev": "concurrently \"bun run watch\" \"bunx wrangler pages dev\" --prefix=none",
        "prepare": "lefthook install"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.101.1",
        "prettier-plugin-toml": "^2.0.6"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "concurrently": "^9.2.1",
        "lefthook": "^2.1.4",
        "license-check-and-add": "^4.0.5",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "supabase": "^2.84.6",
        "wasm-pack": "^0.14.0",
        "wrangler": "^4.79.0"
    }
}
