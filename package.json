{
    "name": "egakareta",
    "scripts": {
        "build": "bun scripts/build.ts",
        "format:cargo": "cargo fmt",
        "format:prettier": "prettier --write .",
        "format": "bun run format:cargo && bun run format:prettier",
        "lint": "cargo clippy -- -D warnings",
        "cf-typegen": "wrangler types --strict-vars=false --env-interface CloudflareEnv functions/cloudflare-env.d.ts",
        "sb-ts-typegen": "supabase gen types typescript --local > functions/_supabase_types.ts",
        "typegen": "bun cf-typegen && bun sb-ts-typegen",
        "test": "cargo test -- -Zunstable-options --format=terse --report-time",
        "test:coverage": "cargo llvm-cov -- -Zunstable-options --format=terse --report-time",
        "test:functions": "vitest run",
        "test:db": "supabase test db",
        "license:add": "license-check-and-add add -f .github/license/config.json",
        "license:check": "license-check-and-add check -f .github/license/config.json",
        "dev:setup": "supabase start && until supabase status; do sleep 2; done && supabase status -o env > .env.local && bun typegen",
        "dev": "bun scripts/dev.ts",
        "prepare": "lefthook install"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.107.0"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.16.13",
        "@types/bun": "^1.3.14",
        "@vitest/coverage-istanbul": "4.1.8",
        "lefthook": "^2.1.9",
        "license-check-and-add": "^4.0.5",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.3",
        "prettier-plugin-toml": "^2.0.6",
        "supabase": "^2.105.0",
        "vitest": "^4.1.8",
        "wasm-pack": "^0.15.0",
        "wrangler": "^4.98.0"
    }
}
