{
    "scripts": {
        "benchmark": "cargo test benchmark_ -- --ignored",
        "build": "wasm-pack build --target web",
        "format:cargo": "cargo fmt",
        "format:prettier": "prettier --write .",
        "format": "bun run format:cargo && bun run format:prettier",
        "lint": "cargo clippy -- -D warnings",
        "test": "cargo test",
        "watch": "nodemon --watch src -e rs,wgsl --exec \"bun run build\"",
        "serve": "bunx serve .",
        "dev": "concurrently \"bun run watch\" \"bun run serve\"",
        "prod": "bun run build && bun dist.js",
        "prepare": "lefthook install"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "lefthook": "^2.1.1",
        "nodemon": "^3.1.11",
        "prettier": "^3.8.1",
        "wasm-pack": "^0.14.0"
    }
}
