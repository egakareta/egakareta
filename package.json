{
    "scripts": {
        "benchmark": "cargo test benchmark_ -- --ignored",
        "build:game": "wasm-pack build --target web --out-dir website/public/pkg/",
        "build:web": "cd website && bun run build",
        "build": "bun prepare:assets && bun build:game && bun build:web",
        "format:cargo": "cargo fmt",
        "format:prettier": "prettier --write .",
        "format": "bun run format:cargo && bun run format:prettier",
        "lint": "cargo clippy -- -D warnings",
        "test": "cargo nextest run",
        "test:coverage": "cargo llvm-cov nextest --lcov --output-path lcov.info",
        "watch": "nodemon --watch src -e rs,wgsl --exec \"bun build:game\"",
        "dev": "concurrently \"bun watch\" \"cd website && bun dev\" --prefix=none",
        "prod": "bun install && bun run build && mv website/out dist",
        "prepare:lefthook": "lefthook install",
        "prepare:assets": "ln -sfn ../../assets website/public/assets",
        "prepare": "bun prepare:lefthook && bun prepare:assets"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "lefthook": "^2.1.1",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "supabase": "^2.76.12",
        "wasm-pack": "^0.14.0"
    },
    "workspaces": [
        "website"
    ]
}
