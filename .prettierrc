{
    "plugins": ["prettier-plugin-toml"],
    "semi": true,
    "singleQuote": false,
    "useTabs": false,
    "tabWidth": 4,
    "overrides": [
        {
            "files": ["*.yml", "*.yaml"],
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": ["*.jsonc"],
            "options": {
                "trailingComma": "none"
            }
        }
    ]
}
