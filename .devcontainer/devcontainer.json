{
    "name": "egakareta game dev",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "runArgs": ["--ipc=host", "--device=/dev/snd"],
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "ms-vscode.cpptools",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "tamasfe.even-better-toml",
                "Supabase.vscode-supabase-extension",
                "foxundermoon.shell-format",
                "vadimcn.vscode-lldb",
                "slevesque.vscode-3dviewer",
                "wgsl-analyzer.wgsl-analyzer",
                "mtxr.sqltools"
            ]
        }
    },
    "postCreateCommand": "git config --global --add safe.directory /workspaces/${localWorkspaceFolderBasename} && bun install && bun run dev:setup",
    "postStartCommand": "bun run dev",
    "remoteUser": "root",
    "forwardPorts": [3000, 54324, 54323, 54321]
}
