{
    "$schema": "../../node_modules/license-check-and-add/config-schema.json",
    "ignoreFile": ".gitignore",
    "ignore": [
        ".wrangler/**",
        "assets/**",
        "supabase/**",
        "**/*.md",
        "**/*.lock",
        "**/*-env.d.ts",
        "**/*_types.ts",
        ".*"
    ],
    "licenseFormats": {
        "ts|js|rs": {
            "eachLine": {
                "prepend": "* "
            },
            "prepend": "/*\n",
            "append": "\n*/"
        },
        "toml|yml|^Dockerfile": {
            "eachLine": {
                "prepend": "# "
            }
        }
    },
    "license": ".github/license/header.txt",
    "defaultFormat": {
        "eachLine": {
            "prepend": " * "
        },
        "prepend": "/*\n",
        "append": "\n */"
    }
}
